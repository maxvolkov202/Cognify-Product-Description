# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle
/drizzle/meta

# serwist (built service worker — emitted on `next build`, not source)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map

# editor
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# audio fixtures (test only)
/tmp/audio/
seed-operator.mjs

.vercel

# local reference transcripts (dropped in by Max for context, not part of repo)
*_transcript.txt
nick_saraev_*.txt
Build_mobile_apps_*.txt

# one-shot debug / probe / audit scripts. CI-grade smoke + audit scripts
# live in scripts/dev/ and ARE committed; these patterns cover the
# investigation-only outputs left over from spelunking.
/scripts/debug-*.mjs
/scripts/probe-*.mjs
/scripts/audit-*.mjs
/scripts/audit-*.json
/scripts/test-*.mjs
/scripts/gaps/
/scripts/_*.mjs

# Playwright artifacts
/test-results/
/playwright-report/

# Playwright auth storage state (contains session tokens)
tests/e2e/authed/.auth/

# stale Vite build output (this app is Next.js; dist/ + root index.html are
# a leftover experimental build, not used or served)
/dist
/index.html

# python bytecode cache (prosody worker)
__pycache__/
*.pyc
