# Cognify v2 — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# --- Database (Neon Postgres) ---
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# --- Auth (Auth.js v5) ---
AUTH_SECRET=""              # openssl rand -base64 32
AUTH_URL="http://localhost:3333"
AUTH_RESEND_KEY=""          # for email passwordless (https://resend.com)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (Resend, used for welcome + /help contact form) ---
RESEND_API_KEY=""
EMAIL_FROM="Cognify <onboarding@resend.dev>"
SUPPORT_INBOX="support@cognifygym.com"

# --- Anthropic (scoring + framework generation) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_SCORING_MODEL="claude-sonnet-4-6"
ANTHROPIC_FRAMEWORK_MODEL="claude-opus-4-6"

# --- Deepgram (speech-to-text) ---
DEEPGRAM_API_KEY=""

# --- Vercel Blob (audio storage) ---
BLOB_READ_WRITE_TOKEN=""

# --- Upstash (rate limiting + streaks) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3333"
NEXT_PUBLIC_MARKETING_MODE="dual"   # dual | enterprise | consumer
