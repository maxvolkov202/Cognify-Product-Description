# Cognify environment — regenerated 2026-07-07 (Phase 16 pre-prod audit).
# Copy to .env.local for dev; never commit .env.local. Tiers mirror the
# prod runbook in plans/prd-implementation-progress.md.

# ── Tier 1 — REQUIRED (app breaks or is unsafe without) ─────────────────
# Supabase Dashboard → Project Settings → Database → Transaction pooler URI
# (password special chars URL-encoded, e.g. ! → %21)
DATABASE_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-<region>.pooler.supabase.com:6543/postgres"
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."           # audio storage + auth admin (delete account)
ANTHROPIC_API_KEY="sk-ant-..."               # boot-required even in openai mode
OPENAI_API_KEY="sk-..."                      # peer provider + ALL embeddings/RAG
DEEPGRAM_API_KEY="..."                       # transcription — the core rep loop
CRON_SECRET="<long-random-32+>"              # all cron routes fail closed without it (prod)
NEXT_PUBLIC_APP_URL="https://cognifygym.com" # absolute links: OG images, emails, invites

# v3 product flags — DEFAULT OFF IN PRODUCTION; all six required to launch v3:
FF_MUSCLE_GROUP_WORKOUT="true"               # off in prod = BetaSoon placeholder, no legacy fallback
FF_TRAINING_ENGINE_V2="true"
FF_SKILL_LAB_APPS="true"
FF_BUILD_A_REP_V2="true"
FF_RANK_SYSTEM="true"                        # also retires the FF_LEAGUES board
FF_PROMPT_GEN="true"

# ── Tier 2 — strongly recommended in production ─────────────────────────
UPSTASH_REDIS_REST_URL=""                    # real rate limiting; absent = per-instance memory window
UPSTASH_REDIS_REST_TOKEN=""
RESEND_API_KEY=""                            # welcome/support/committed-day-reminder emails (silent no-op without)
EMAIL_FROM="Cognify <hello@cognifygym.com>"  # default is onboarding@resend.dev — set this
SUPPORT_INBOX="support@cognifygym.com"
CALIBRATION_ALERT_WEBHOOK_URL=""             # scoring-drift alerts (Slack webhook etc.)
OPS_SECRET=""                                # detailed /api/health body (falls back to CRON_SECRET)

# ── Tier 3 — AI provider + tuning (safe code defaults; uncomment to override) ──
# AI_PROVIDER="anthropic"                    # "anthropic" | "openai" — governs EVERY AI path (Phase 14)
# SCORING_PROVIDER=""                        # legacy alias for AI_PROVIDER
# ANTHROPIC_SCORING_MODEL="claude-haiku-4-5-20251001"
# ANTHROPIC_FRAMEWORK_MODEL="claude-sonnet-4-6"
# OPENAI_FALLBACK_MODEL="gpt-4o"             # both-roles default on the OpenAI side
# OPENAI_SCORING_MODEL=""                    # per-role overrides
# OPENAI_FRAMEWORK_MODEL=""
# SCORING_ANTHROPIC_TIMEOUT_MS="5000"
# SCORING_OPENAI_TIMEOUT_MS="15000"
# AI_GEN_ANTHROPIC_TIMEOUT_MS="90000"
# AI_GEN_OPENAI_TIMEOUT_MS="120000"
# AI_BREAKER_COOLDOWN_MS="120000"            # dead-provider circuit breaker cooldown
# DRIFT_TOLERANCE=""                         # default 5 (anthropic) / 12 (openai)
# XP_MODE_WEIGHTS=""                         # JSON, e.g. {"skill_lab":0.9}
# RAG_RETRIEVE_TIMEOUT_MS="1500"
# RAG_RETRIEVE_TOP_K="8"
# RAG_RETRIEVE_RETURN_COUNT="6"
# RAG_REFREPS_TIMEOUT_MS="1000"
# RAG_REFREPS_TOP_K="2"
# RAG_REFREPS_SIMILARITY_THRESHOLD="0.7"

# ── Tier 4 — optional features (default off unless noted) ───────────────
# FF_RAG_RETRIEVE="true"                     # default ON — set "false" to disable
# FF_REFERENCE_REPS="true"                   # default ON — set "false" to disable
# FF_DETERMINISTIC_SIGNALS="false"
# FF_DETERMINISTIC_SIGNALS_PERCENT="0"
# FF_BAND_ANCHORS="false"
# FF_BAND_ANCHORS_PERCENT="0"
# FF_LEAGUES="false"                         # retired when FF_RANK_SYSTEM is on
# FF_SUBSKILL_UI="false"                     # retired per D5
# FF_BUILD_A_REP_PREMIUM="false"             # true LOCKS EVERYONE out of Build a Rep (entitlement stub)
# FF_PROSODY_WORKER="false"
# PROSODY_WORKER_URL=""
# PROSODY_WORKER_TOKEN=""
# HUME_API_KEY=""
# NEXT_PUBLIC_USE_ASYNC_SCORING="false"      # build-time (client); needs INTERNAL_SCORING_SECRET
# INTERNAL_SCORING_SECRET=""                 # ≥16 chars; /api/score-internal auth
