# Cognify v2 — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# --- Database (Supabase Postgres via Transaction pooler) ---
# Supabase Dashboard → Project Settings → Database → Connection String → Transaction pooler → URI
# Password special chars must be URL-encoded (e.g. ! → %21).
DATABASE_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-<region>.pooler.supabase.com:6543/postgres"

# --- Supabase (Auth + Storage + Edge Functions) ---
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""         # sb_publishable_... — safe for the browser
SUPABASE_SERVICE_ROLE_KEY=""             # sb_secret_... — SERVER-ONLY, never expose

# --- Anthropic (scoring + framework generation) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_SCORING_MODEL="claude-sonnet-4-6"
ANTHROPIC_FRAMEWORK_MODEL="claude-opus-4-6"

# --- Deepgram (speech-to-text with word-level timestamps) ---
DEEPGRAM_API_KEY=""

# --- Email (Resend) — optional, for welcome + /help contact form ---
RESEND_API_KEY=""
EMAIL_FROM="Cognify <onboarding@resend.dev>"
SUPPORT_INBOX="support@cognifygym.com"

# --- Upstash Redis — optional, for rate limiting + streak counters ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3333"
NEXT_PUBLIC_MARKETING_MODE="dual"        # dual | enterprise | consumer

# --- Phase 4 async Edge Function (optional) ---
# Shared secret between Next.js /api/score-internal and the process-rep Edge
# Function. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SCORING_SECRET=""
NEXT_PUBLIC_USE_ASYNC_SCORING="false"    # flip to "true" after deploying process-rep
